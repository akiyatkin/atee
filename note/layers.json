{
	"index":"index:ROOT",	
	"json":{
		"note-theory:BUTTON":"/-user/get-user",
		"note-theory:ALL":"/-note/get-theory-note-all",
		"note-admin:ROOT":"/-note/get-admin"
	},
	"parsedtpl":{
		"note-admin:NOTESROOT":"${env.bread.search}"
	},
	"jsontpl":{
		"note-theory:CONTROL":"/-note/get-theory-control?note=${env.crumb.name}",
		"note-theory:PAGE":"/-note/get-theory-note-page?note=${env.crumb.name}",
		"note-theory:EDIT":"/-note/get-theory-note-edit?note=${env.crumb.name}",
		"note-theory:LIST":"/-note/get-theory-search?query=${env.bread.get.query ?? ''}",
		"note-admin:NOTESROOT":"/-note/get-admin-notes-root?id=${env.bread.get.id ?? ''}",
		"note-admin:NOTESLIST":"/-note/get-admin-notes-list?endorsement=${env.bread.get.endorsement ?? ''}&query=${env.bread.get.query ?? ''}&inside=${env.bread.get.inside ?? ''}&create=${env.bread.get.create ?? ''}&change=${env.bread.get.change ?? ''}&id=${env.bread.get.id ?? ''}&sort=${env.bread.get.sort ?? ''}",
		"note-admin:PROPS":"/-note/get-admin-note?note_id=${env.crumb.name}",
		"note-admin:HISTORY":"/-note/get-admin-history?note_id=${env.crumb.name}",
		"note-admin:REV":"/-note/get-admin-history-rev?note_id=${env.crumb.parent.name}&rev=${env.crumb.name}",
		"index:ROOT":"/-sitemap/get-head?path=${env.bread.path}&root=${env.bread.root}",

		"note-layout:MAIN":"/-note/get-note?note=${env.crumb.name}",
		"note-props:ROOT":"/-note/get-note-props?note=${env.crumb.parent.name}",
		"note-props:REV":"/-note/get-note-rev?note=${env.crumb.parent.parent.name}&rev=${env.crumb.name}"
	},
	"tpl":{
		"note-layout":"/-note/layout.html.js",
		"note-props":"/-note/props.html.js",
		"frame":"/-controller/frame.html.js",
		"controller":"/-controller/layout.html.js",
		"index":"/-controller/index-board.html.js",
		"aside":"/-note/aside.html.js",
		"note-admin":"/-note/admin.html.js",
		"note-theory":"/-note/theory.html.js"
	},
	"head":{
		"title":"Административный кабинет"
	},
	"layout":{
		"index:ROOT": {
			"MAIN":"note-admin:ROOT",
			"ASIDE":"aside:ROOT"
		}
	},	
	"childs":{
		"edit":{
			"layout":{},
			"child":{
				"checktpl":"/-get-note-check?note=${env.crumb.name}&path=@atee/note/theory/edit",
				"head":{"jsontpl":"/-get-note-head?note=${env.crumb.name}"},
				"layout":{
					"index:ROOT":{
						"MAIN":"note-layout:MAIN"
					}
				},
				"childs":{
					"props":{
						"head":{ "title":"Свойства" },
						"layout":{
							"index:ROOT":{
								"MAIN":"note-props:ROOT"
							}
						},
						"child":{
							"layout":{
								"index:ROOT":{
									"MAIN":"note-props:REV"
								}
							}
						}
					}
				}
			}
		},
		"theory":{
			"head":{"title":"Журнал"},
			"layout":{
				"index:ROOT":{
					"MAIN":"note-theory:ROOT"
				},
				"note-theory:ROOT":{
					"BUTTON":"note-theory:BUTTON",
					"LIST":"note-theory:LIST"
				}
			},
			"childs":{
				"all":{
					"head":{ "hidden":true, "title":"Все записи" },
					"layout":{
						"index:ROOT":{
							"MAIN":"note-theory:ALL"
						}
					}
				},
				
				"note":{
					"layout":{},
					"child":{
						"head":{"jsontpl":"/-note/get-theory-head?note=${env.crumb.name}"},
						"checktpl":"/-note/get-theory-note-check?note=${env.crumb.name}&path=@atee/note/theory/note/",
						"layout":{
							"index:ROOT":{
								"MAIN":"note-theory:PAGE"
							},
							"theory:PAGE":{
								"CONTROL":"note-theory:CONTROL"
							}
						}
					}
				}
			}
		},
		"history":{
			"child":{
				"head":{ "title":"История" },
				"layout":{
					"index:ROOT":{
						"MAIN":"note-admin:HISTORY"
					}
				},
				"child":{
					"head":{ "title":"Заметка в истории" },
					"layout":{
						"index:ROOT":{
							"MAIN":"note-admin:REV"
						}
					}
				}
			}
		},
		"props":{
			"child":{
				"head":{ "title":"Свойства заметки" },
				"layout":{
					"index:ROOT":{
						"MAIN":"note-admin:PROPS"
					}
				}
			}
		},
		"notes":{
			"head":{ "title":"Список заметок", "hidden":true },
			"layout":{
				"index:ROOT":{
					"MAIN":"note-admin:NOTESROOT"
				},
				"note-admin:NOTESROOT":{
					"NOTESLIST":"note-admin:NOTESLIST"
				}
			}
		},
		"error":{
			"head":{"hidden":true, "title":"Ошибка"},
			"layout":{
				"index:ROOT":{
					"MAIN":"controller:ERROR"
				}
			}
		}
	}
}